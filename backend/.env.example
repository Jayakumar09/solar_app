# Backend Environment Configuration
# Copy this file to .env and update with your production values

# Server
PORT=5000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://greenhybridpower.in

# PostgreSQL Database URL - Use Supabase Pooler (port 6543)
# Format: postgresql://username:password@pooler-host:port/database_name?sslmode=require
DATABASE_URL=postgresql://postgres:password@aws-0.ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# JWT Secret (use a strong, random string - minimum 32 characters)
JWT_SECRET=your-jwt-secret-min-32-chars